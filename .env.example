# Warehouse Pro Mobile — Environment Variables
# Copy this file to .env.local and fill in the values

# API URL (default: https://api.warehousepro.uz)
EXPO_PUBLIC_API_URL=

# Yandex Maps API Key (required for map features)
# Get yours at https://developer.yandex.com/maps/
EXPO_PUBLIC_YANDEX_MAPS_API_KEY=
